    {
      "beat_id": "B07",
      "act": "mechanism 3",
      "narration_text": "Mechanism three: stop at the card. Scout writes the card detailed enough that a builder can turn an approved one into a beat sheet with no further reading — but scout never writes narration, never writes beats, never builds a scene. The boundary is absolute.",
      "voice": "am_onyx",
      "engine": "kokoro",
      "estimated_duration_s": 22,
      "shot": {
        "type": "REMOTION",
        "remotion": {
          "pattern": "SkillTeardownMechanism",
          "props": {
            "eyebrow": "MECHANISM · ACT 3",
            "heading": "The card is the handoff.",
            "body": "A scout card must be self-contained: the concept, the question, the key case, the core idea, the visual object, the exclusions. That is enough for a builder. Going further — writing narration, writing beats — crosses the boundary. Scout produces cards. Builders produce films.",
            "quote": "Never write narration, beats, or scenes here. Stop at the card.",

    {
      "beat_id": "B06",
      "act": "mechanism 2",
      "narration_text": "Mechanism two: the vox bar. Every concept that clears the motion test still has to clear the question test. If you can't write the question as a gap formula and name a concrete key case, the concept isn't a card yet. These two checks together are the filter.",
      "voice": "am_onyx",
      "engine": "kokoro",
      "estimated_duration_s": 22,
      "shot": {
        "type": "REMOTION",
        "remotion": {
          "pattern": "SkillTeardownMechanism",
          "props": {
            "eyebrow": "MECHANISM · ACT 2",
            "heading": "No question, no card.",
            "body": "The vox bar requires two things before a concept becomes a card: a question that can be written as a gap formula (the HOW or WHY, not a definition), and a concrete key case that demonstrates the mechanism. If either is missing, the concept is not yet scoped enough to film.",
            "quote": "if you cannot write THE QUESTION as a gap formula and name a concrete KEY CASE, the concept is not a card yet.",
            "cite": "skills/make/scout/SKILL.md — scout command step 3",
            "verdictLabel": "VOX BAR"
          },
          "rendered": {
            "out": "media/B06.mp4",
            "at": ""
          }
        }

    {
      "beat_id": "B05",
      "act": "mechanism 1",
      "narration_text": "Mechanism one: selectivity, not coverage. Scout reads every chapter but passes on most of it. A chapter yields zero, one, or several candidates — all are correct. The skill's value is knowing what to skip.",
      "voice": "am_onyx",
      "engine": "kokoro",
      "estimated_duration_s": 20,
      "shot": {
        "type": "REMOTION",
        "remotion": {
          "pattern": "SkillTeardownMechanism",
          "props": {
            "eyebrow": "MECHANISM · ACT 1",
            "heading": "Most content is not a film.",
            "body": "Scout detects high-assertion zones — regions where a concept is dense enough to show on screen — then applies the motion test. Zones that don't require movement to teach are cut. A chapter can produce zero cards and that is correct: coverage is not the goal.",
            "quote": "Your value is selectivity, not coverage: most chapter content is not a film.",
            "cite": "skills/make/scout/SKILL.md — core principle",
            "verdictLabel": "SELECTIVITY"
          },
          "rendered": {
            "out": "media/B05.mp4",
            "at": ""
          }
        }
      },
      "audio_file": "mp3/beat-B05.mp3",

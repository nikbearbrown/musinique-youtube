    {
      "beat_id": "B02",
      "scene": "B02_OutputComponents",
      "narration_text": "The generated template has six components. Role: who Claude is in this task. Context: what background it needs. Input format: how data arrives. Instructions: step-by-step task logic. Output format: what the response looks like. Edge cases: explicit handling for exceptions. All six are generated from your two-sentence description. You review, edit, and promote to production.",
      "voice": "am_onyx",
      "engine": "kokoro",
      "shot": {

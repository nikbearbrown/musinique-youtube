    {
      "beat_id": "B03",
      "scene": "B03_WhenToUse",
      "narration_text": "Use the metaprompt to bootstrap. Never ship its output without review. The metaprompt cannot know your specific data schema, your edge cases from production, or the failures you've already seen. It produces a strong first draft, not a final prompt. The workflow is: generate, test on real inputs, iterate. The blank page is gone. The judgment is still yours.",
      "voice": "am_onyx",
      "engine": "kokoro",
      "shot": {
        "manim": {

    {
      "beat_id": "B02",
      "t_start": 33.0,
      "estimated_duration_s": 16.0,
      "narration_text": "The dot-env file controls which features are active. Kokoro voice is free and local — no key needed. If you leave the ElevenLabs key blank, narration still works. The only required keys are for Claude Code itself. The setup script tells you exactly what's missing.",
      "shot": {
        "type": "CARD",
        "source": "remotion",
        "motion": "fade",
        "remotion": {
          "pattern": "ClaudeCodeBeat",
          "props": {
            "title": ".env.example",
            "code": "# Required for Claude Code:\nANTHROPIC_API_KEY=your-key\n\n# Optional — narration:\nELEVENLABS_API_KEY=   # leave blank for Kokoro (free)\n\n# Validate:\n./art keys",
            "sparkLine": "Free by default."
          },
          "rendered": {

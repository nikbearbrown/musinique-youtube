        "filled_by": "media",
        "at": "2026-07-17T19:18:45"
      }
    },
    {
      "beat_id": "B03",
      "t_start": 49.0,
      "estimated_duration_s": 15.0,
      "narration_text": "Once it's set up, you give it a prompt and walk away. Claude Code runs every stage in sequence. Audio is generated first because narration is the master clock — all on-screen timing conforms to your voice, not the other way around.",
      "shot": {
        "type": "CARD",
        "source": "remotion",
        "motion": "fade",
        "remotion": {

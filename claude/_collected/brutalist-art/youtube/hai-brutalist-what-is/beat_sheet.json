          "props": {
            "view": "artifact",
            "artifactTitle": "Audio-first principle",
            "artifactHeading": "Why narration goes first",
            "artifactLines": [
              "Narration is generated and measured.",
              "Actual MP3 duration becomes the beat clock.",
              "Every visual conforms to that duration.",
              "Never fix timing by hand — re-generate audio."
            ],
            "sparkLine": "The voice sets the pace."
          },
          "rendered": {
            "out": "media/B03.mp4",
            "at": ""

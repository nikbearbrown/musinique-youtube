    {
      "beat_id": "B02",
      "t_start": 33.0,
      "estimated_duration_s": 16.0,
      "narration_text": "The setup is simple. Copy the example dot-env file, fill in your keys, run setup dash dash install, then run dot-slash-art keys. If everything is green, you're ready. Kokoro voice is free and local — no keys needed for narration.",
      "shot": {
        "type": "CARD",
        "source": "remotion",
        "motion": "fade",
        "remotion": {
          "pattern": "ClaudeCodeBeat",
          "props": {
            "title": "setup check",
            "code": "cp .env.example .env\n# fill in your keys\n./setup --install\n./art keys\n# ALL GREEN ✓",
            "sparkLine": "Green means go."
          },
          "rendered": {
            "out": "media/B02.mp4",
            "at": ""
          }
        }
      },
      "audio_file": "mp3/beat-B02.mp3",
      "actual_duration_s": 13.61,
      "build": {
        "status": "VIDEO",

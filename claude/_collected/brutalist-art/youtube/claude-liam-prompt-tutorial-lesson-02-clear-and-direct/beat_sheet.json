      "props": {
        "greeting": "Aloha, Liam",
        "topic": "PROMPT ENGINEERING · ANTHROPIC",
        "segment": "Clear and Direct: Why Vague Prompts Produce Vague Outputs",
        "command": "Vague prompts produce vague outputs. That is not a model limitation — it is a specification failure. Claude is a literal instruction-follower. If you leave room for interpretation, it will interpret. The fix is to be specific.",
        "runningText": "reading the tutorial…",
        "folderLabel": "@NikBearBrown",
        "modelLabel": "Fable 5",
        "effortLabel": "High"
      },

        "type": "GRAPHIC",
        "motion": "morph"
      },
      "narration_text": "Those neutrophils carry the original IDH1 mutation in their genome. They were the cancer. They grew up.",
      "estimated_duration_s": 10.0,
      "audio_file": "../vox-differentiation-therapy/mp3/beat-B03.mp3",

    {
      "beat_id": "B05",
      "t_start": 44.0,
      "estimated_duration_s": 13.0,
      "narration_text": "Lab B's density matrix: half the time |+\u27e9, half the time |\u2212\u27e9. Work out the arithmetic and you get \u2014 exactly the same matrix. Identity divided by two.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "drawon"
      },
      "new_visual_element": "[MATRIX] Lab B = (1/2)|+><+| + (1/2)|-><-| = I/2",

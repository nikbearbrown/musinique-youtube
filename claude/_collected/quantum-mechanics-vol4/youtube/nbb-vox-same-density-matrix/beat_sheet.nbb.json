        "motion": "drawon"
      },
      "new_visual_element": "[MATRIX] Lab A = (1/2)|0><0| + (1/2)|1><1| = I/2",
      "audio_file": "../vox-same-density-matrix/mp3/beat-B04.mp3",
      "actual_duration_s": 11.28,
      "locked": true,
      "source_clip": "../vox-same-density-matrix/clips/B04.mp4",

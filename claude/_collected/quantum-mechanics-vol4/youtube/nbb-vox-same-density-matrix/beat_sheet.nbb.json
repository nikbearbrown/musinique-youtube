    {
      "beat_id": "B02",
      "t_start": 9.0,
      "estimated_duration_s": 12.0,
      "narration_text": "You measure in every direction you can think of. Z-axis: fifty-fifty from both labs. X-axis: fifty-fifty from both. Y-axis: fifty-fifty. Every single axis gives the same result from both labs.",

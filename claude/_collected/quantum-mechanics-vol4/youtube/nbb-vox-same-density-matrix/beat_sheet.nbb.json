    {
      "beat_id": "B07",
      "t_start": 62.0,
      "estimated_duration_s": 14.0,
      "narration_text": "Every qubit state lives on or inside the Bloch ball. Pure states sit on the surface. Mixed states live in the interior. The maximally mixed state \u2014 identity over two \u2014 sits at the exact center, with Bloch vector zero.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "drawon"

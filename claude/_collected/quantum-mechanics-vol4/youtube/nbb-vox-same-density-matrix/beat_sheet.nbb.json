      "locked": true,
      "source_clip": "../vox-same-density-matrix/clips/B03.mp4",
      "source_audio": "../vox-same-density-matrix/mp3/beat-B03.mp3"
    },
    {
      "beat_id": "B04",
      "t_start": 31.0,
      "estimated_duration_s": 13.0,
      "narration_text": "Lab A's density matrix: half the time |0\u27e9, half the time |1\u27e9. That is a diagonal matrix with one-half on every diagonal entry \u2014 the identity divided by two.",
      "shot": {
        "type": "GRAPHIC",

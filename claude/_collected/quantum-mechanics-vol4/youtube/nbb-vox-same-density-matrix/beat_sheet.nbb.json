    {
      "beat_id": "B12",
      "t_start": 113.0,
      "estimated_duration_s": 12.0,
      "narration_text": "The density matrix is a prediction machine for measurements \u2014 not a record of preparation history. Two sources with identical measurement statistics for every observable are, by definition, the same quantum state.",

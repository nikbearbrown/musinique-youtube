      "card": {
        "kind": "dek",
        "copy": "Why can\u2019t the density matrix\ntell the two labs apart?",
        "sub": "THE QUESTION"
      },
      "new_visual_element": "[QUESTION] density matrix can't distinguish labs",
      "audio_file": "../vox-same-density-matrix/mp3/beat-B03.mp3",

    },
    {
      "beat_id": "B09",
      "t_start": 81.0,
      "estimated_duration_s": 12.0,
      "narration_text": "In every single row, one bracket is plus or minus two and the other is zero. Never both nonzero. Since A1 and A2 each have absolute value one, the magnitude of S for this lambda is always one times two plus one times zero — exactly two.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "drawon"
      },
      "new_visual_element": "[TABLE] same table with |S(lambda)|=2 column added and highlighted",

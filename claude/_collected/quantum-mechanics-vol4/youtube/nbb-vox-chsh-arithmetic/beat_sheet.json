        "type": "CARD",
        "source": "own",
        "motion": "hold",
        "remotion": {
          "pattern": "SlateCard",
          "provenance": "proven-core/SlateCard",
          "version": "1",
          "props": {
            "headline": "Alice and Bob run an experiment. Each has two measurement settings.…",
            "eyebrow": "",
            "topic": ""
          }
        }
      },
      "card": {
        "kind": "title",
        "copy": "S = E(A1,B1) + E(A1,B2)\n   + E(A2,B1) − E(A2,B2)",
        "sub": "THE CHSH PARAMETER"
      },
      "new_visual_element": "[TITLE] CHSH setup",
      "audio_file": "../vox-chsh-arithmetic/mp3/beat-B01.mp3",
      "actual_duration_s": 13.04,
      "locked": true,

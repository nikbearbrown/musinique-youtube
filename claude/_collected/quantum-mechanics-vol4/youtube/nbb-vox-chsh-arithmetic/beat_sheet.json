    {
      "beat_id": "B01",
      "t_start": 0.0,
      "estimated_duration_s": 10.0,
      "narration_text": "Alice and Bob run an experiment. Each has two measurement settings. Each records plus one or minus one. A single number — the CHSH parameter S — is built from their four correlation values.",

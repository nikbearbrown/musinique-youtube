    {
      "beat_id": "B08",
      "t_start": 67.0,
      "estimated_duration_s": 14.0,
      "narration_text": "Write all four possible B1, B2 assignments. Row one: both plus one — sum is plus two, difference is zero. Row two: plus one, minus one — sum is zero, difference is plus two. Row three: minus one, plus one — sum is zero, difference is minus two. Row four: both minus one — sum is minus two, difference is zero.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "drawon"
      },
      "new_visual_element": "[TABLE] 4 rows: B1,B2 | B1+B2 | B1-B2",

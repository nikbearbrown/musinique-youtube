    {
      "beat_id": "B06",
      "t_start": 49.0,
      "estimated_duration_s": 13.0,
      "narration_text": "Write out S for one instruction set: A1 times B1 plus B2, plus A2 times B1 minus B2. Two terms. Each bracket is a sum or difference of plus-one and minus-one numbers. There are only four possible assignments for the pair B1, B2.",
      "shot": {

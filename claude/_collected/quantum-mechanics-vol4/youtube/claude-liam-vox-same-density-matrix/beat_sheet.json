    {
      "beat_id": "B08",
      "t_start": 76.0,
      "estimated_duration_s": 14.0,
      "narration_text": "Lab A averages the north pole and the south pole. The midpoint of that pair is the center. Lab B averages the east pole and the west pole. The midpoint of that pair is also the center. Different pairs, same center.",

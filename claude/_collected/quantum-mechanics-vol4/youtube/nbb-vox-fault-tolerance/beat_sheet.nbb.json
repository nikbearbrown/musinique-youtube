    },
    {
      "beat_id": "B05",
      "t_start": 44.0,
      "estimated_duration_s": 5.0,
      "narration_text": "Because the ancilla is not a bystander.",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "hold",
        "remotion": {
          "pattern": "SlateCard",
          "provenance": "proven-core/SlateCard",

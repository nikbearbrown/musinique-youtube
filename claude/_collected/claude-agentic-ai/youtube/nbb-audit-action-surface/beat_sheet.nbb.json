      "beat_id": "B01",
      "act": "PROBLEM -- why care",
      "role_note": "the problem, context, stakes -- BEFORE the CLI opens",
      "narration_text": "Date extraction from twelve contracts needs read access and one CSV write. Nothing else. The action surface audit cuts browser access, terminal commands, and write-to-source before the agent touches a file. The blast radius of any error scales with the surface, not the task.",
      "visual_intent": "SLATE -- title card: BLAST RADIUS scales with the action surface, not the task complexity.",
      "shot": {
        "type": "GRAPHIC",
        "source": null,
        "motion": "fade"

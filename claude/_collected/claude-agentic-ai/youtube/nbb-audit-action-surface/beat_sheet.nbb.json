      "act": "ASK",
      "role_note": "terminal (Onda) -- the command typed",
      "narration_text": "Ask Claude to generate a permission matrix for the task -- access type, read-write, reversibility, blast radius, and required flag for each.",
      "shot": {
        "type": "GRAPHIC",
        "source": "remotion",
        "motion": "fade",
        "remotion": {
          "pattern": "NikBearBrownTerminalAsk",
          "props": {

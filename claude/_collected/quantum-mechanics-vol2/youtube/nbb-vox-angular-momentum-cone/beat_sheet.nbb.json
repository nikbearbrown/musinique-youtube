  "beats": [
    {
      "beat_id": "NBB00",
      "act": "COLD OPEN",
      "title": "Liam cold open \u2014 ClaudeComposerAsk",
      "engine": "kokoro",
      "voice": "am_onyx",
      "narration_text": "Salut, Liam \u2014 in for Bear. Those two numbers are never equal \u2014 so the vector can never line up with the axis? Can you explain it, Bear?",
      "shot": {
        "type": "CARD",
        "source": "remotion",
        "motion": "hold",
        "remotion": {
          "pattern": "ClaudeComposerAsk",
          "provenance": "proven-core/ClaudeComposerAsk",
          "version": "1",
          "props": {

          },
          "rendered": {
            "out": "media/B03.mp4",
            "at": ""
          }
        }
      },
      "card": {
        "headline": "Classical physics predicts infinite energy. A real oven has a finite peak. Why?",
        "style": "question"
      },
      "audio_file": "../vox-planck-catastrophe/mp3/beat-B03.mp3",
      "locked": true,
      "source_clip": "../vox-planck-catastrophe/clips/B03.mp4",

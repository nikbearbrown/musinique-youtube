            "at": ""
          }
        }
      },
      "audio_file": "../vox-planck-catastrophe/mp3/beat-B04.mp3",
      "locked": true,
      "source_clip": "../vox-planck-catastrophe/clips/B04.mp4",
      "source_audio": "../vox-planck-catastrophe/mp3/beat-B04.mp3"
    },
    {
      "beat_id": "B05",
      "t_start": 42,
      "estimated_duration_s": 4,
      "narration_text": "The mechanism: discrete energy packets.",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "hold",
        "remotion": {
          "pattern": "SlateCard",
          "provenance": "proven-core/SlateCard",

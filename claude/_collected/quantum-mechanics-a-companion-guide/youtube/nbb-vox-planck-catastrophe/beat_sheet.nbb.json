            "topic": "QUANTUM MECHANICS"
          },
          "rendered": {
            "out": "media/B02.mp4",
            "at": ""
          }
        }
      },
      "audio_file": "../vox-planck-catastrophe/mp3/beat-B02.mp3",
      "locked": true,

    {
      "beat_id": "B04",
      "t_start": 29,
      "estimated_duration_s": 13,
      "narration_text": "In 1900, Max Planck found a formula that fit the measurements perfectly. His key assumption: the cavity walls can only exchange energy with the field in discrete chunks \u2014 multiples of h\u03bd, where h is a new constant of nature and \u03bd is frequency. The energy is quantized.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "accumulate",
        "remotion": {
          "pattern": "SlateCard",
          "provenance": "proven-core/SlateCard",
          "version": "1",
          "props": {

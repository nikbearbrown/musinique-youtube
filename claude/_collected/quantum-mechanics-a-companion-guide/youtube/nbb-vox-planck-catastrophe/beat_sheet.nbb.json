    {
      "beat_id": "B06",
      "t_start": 46,
      "estimated_duration_s": 14,
      "narration_text": "At low frequency, h\u03bd is tiny compared to thermal energy kT \u2014 the classical result is recovered. At high frequency, h\u03bd is much larger than kT \u2014 the mode cannot afford even one packet. It stays empty. The curve bends back down and the catastrophe disappears.",
      "shot": {
        "type": "GRAPHIC",

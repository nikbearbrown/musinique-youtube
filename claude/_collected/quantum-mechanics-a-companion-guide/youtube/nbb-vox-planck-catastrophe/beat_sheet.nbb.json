    {
      "beat_id": "B02",
      "t_start": 7,
      "estimated_duration_s": 13,
      "narration_text": "A hollow box at a fixed temperature holds electromagnetic waves \u2014 many modes at many frequencies. Classical thermodynamics assigns every mode the same average energy, kT, by the equipartition theorem. The energy density at each frequency rises as the square of the frequency. Keep summing and you get infinity.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",

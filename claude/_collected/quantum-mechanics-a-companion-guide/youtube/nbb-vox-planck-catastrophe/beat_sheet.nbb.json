      "source_audio": "../vox-planck-catastrophe/mp3/beat-B02.mp3"
    },
    {
      "beat_id": "B03",
      "t_start": 20,
      "estimated_duration_s": 9,
      "narration_text": "Experiments showed a finite spectrum with a peak: energy rises at low frequencies, hits a maximum, then drops off sharply at high frequencies. There is no catastrophe in nature. Classical physics predicts infinite energy. The real oven doesn't deliver it. Why?",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "hold",
        "remotion": {
          "pattern": "SlateCard",
          "provenance": "proven-core/SlateCard",
          "version": "1",

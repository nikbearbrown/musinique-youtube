    {
      "beat_id": "B11",
      "t_start": 91.0,
      "estimated_duration_s": 9.0,
      "narration_text": "A single eigenstate is silent because its phase is unobservable alone. Only when two eigenstates coexist does the relative phase become real \u2014 and it ticks at the Bohr frequency.",

    {
      "beat_id": "B10",
      "t_start": 80.0,
      "estimated_duration_s": 11.0,
      "narration_text": "The hydrogen Balmer series \u2014 four visible lines \u2014 each one a different pair of energy levels. Red: n=3 to n=2. Blue-green: n=4 to n=2. The phases beat, the electron oscillates, the photon escapes.",

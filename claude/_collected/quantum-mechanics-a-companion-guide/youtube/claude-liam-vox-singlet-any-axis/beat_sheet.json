    },
    {
      "beat_id": "B05",
      "estimated_duration_s": 11,
      "narration_text": "Now rotate both analyzers together from z toward x. A generic spin state changes its coordinates, but the singlet keeps the same up-down minus down-up form in the rotated basis.",

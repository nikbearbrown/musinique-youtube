    {
      "beat_id": "B12",
      "t_start": 105,
      "estimated_duration_s": 3,
      "narration_text": "The numbers: κ for a one-eV barrier.",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "hold"
      },
      "card": {

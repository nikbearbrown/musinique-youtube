    {
      "beat_id": "B11",
      "t_start": 93,
      "estimated_duration_s": 12,
      "narration_text": "The same physics explains alpha decay. A helium nucleus trapped in a uranium nucleus tunnels through a Coulomb barrier — a one-page calculation predicts half-lives across 24 orders of magnitude.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",

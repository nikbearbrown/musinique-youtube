        "type": "CARD",
        "source": "remotion",
        "motion": "hold",
        "remotion": {
          "pattern": "ClaudeComposerAsk",
          "provenance": "proven-core/ClaudeComposerAsk",
          "version": "1",
          "props": {
            "command": "Why can bright red light fail to eject electrons while dim violet light succeeds?",
            "topic": "QUANTUM MECHANICS — PHOTOELECTRIC EFFECT",
            "segment": "Frequency Sets the Threshold",
            "greeting": "Hallo, Liam",
            "runningText": "testing photon energy against a metal…",
            "output": [
              "Brightness changes photon arrival rate.",
              "Frequency changes energy per photon."
            ],
            "folderLabel": "@NikBearBrown",

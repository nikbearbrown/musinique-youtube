        "at": "2026-07-18T15:09:40"
      }
    },
    {
      "beat_id": "B10",
      "estimated_duration_s": 10,
      "narration_text": "Change the potential away from exact one over r, or add electron-electron repulsion, and the simple accident breaks. Energies generally depend on more quantum numbers and the degeneracy splits.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "split"
      },
      "audio_file": "mp3/beat-B10.mp3",

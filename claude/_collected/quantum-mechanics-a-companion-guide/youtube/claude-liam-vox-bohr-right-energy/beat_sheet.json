      }
    },
    {
      "beat_id": "B11",
      "estimated_duration_s": 10,
      "narration_text": "Even hydrogen's measured spectrum contains fine structure, recoil, and Lamb shifts absent from Bohr's formula. The exact match belongs to the ideal nonrelativistic Coulomb Hamiltonian.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "zoom"

    {
      "beat_id": "B01",
      "estimated_duration_s": 9,
      "narration_text": "This is Liam, in for Bear. A table is mostly empty space, and so is your hand. Yet your hand stops cold at the surface. What, exactly, says no?",
      "shot": {
        "type": "CARD",
        "source": "remotion",
        "motion": "hold",
        "remotion": {
          "pattern": "ClaudeComposerAsk",
          "provenance": "proven-core/ClaudeComposerAsk",
          "version": "1",
          "props": {
            "command": "If atoms are mostly empty space, why doesn't your hand pass through a table?",
            "topic": "QUANTUM MECHANICS — SOLID MATTER",
            "segment": "Why Your Hand Doesn't Fall Through the Table",
            "greeting": "Hallo, Liam",
            "runningText": "testing atomic overlap…",
            "output": [
              "Electric forces matter.",
              "Pauli exclusion keeps electrons from collapsing into the same states."
            ],
            "folderLabel": "@NikBearBrown",

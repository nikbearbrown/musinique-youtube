      }
    },
    {
      "beat_id": "B09",
      "estimated_duration_s": 11,
      "narration_text": "The operators do more than label energies. They connect the wavefunctions: raising adds one node, lowering removes one. The complicated family of oscillator shapes becomes a single connected sequence.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "transform"
      },
      "audio_file": "mp3/beat-B09.mp3",
      "actual_duration_s": 11.61,

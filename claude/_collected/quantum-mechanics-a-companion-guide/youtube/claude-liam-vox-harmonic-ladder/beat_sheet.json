        "at": "2026-07-18T13:22:54"
      }
    },
    {
      "beat_id": "B10",
      "estimated_duration_s": 13,
      "narration_text": "Worked picture: begin at n equals zero with energy one half h bar omega. Raise three times. The state visits n equals one, two, and three while the energy advances by exactly h bar omega at every move. Lower once and it returns to n equals two.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "trace"
      },
      "audio_file": "mp3/beat-B10.mp3",
      "actual_duration_s": 14.98,

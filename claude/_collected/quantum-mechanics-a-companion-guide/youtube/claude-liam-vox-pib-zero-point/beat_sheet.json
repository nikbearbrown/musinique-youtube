    {
      "beat_id": "B13",
      "t_start": 112.0,
      "estimated_duration_s": 18,
      "narration_text": "Box width 0.5 nanometers — roughly an atomic diameter. Ground state energy E-one equals pi-squared h-bar-squared over 2 m L-squared. Plug in the numbers: E-one equals about 1.5 eV. Double the box width: E-one drops by a factor of four, to about 0.37 eV. The energy floor scales as one over L squared — confinement writes the floor.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "animate"
      },
      "audio_file": "mp3/beat-B13.mp3",
      "actual_duration_s": 20.95,
      "build": {

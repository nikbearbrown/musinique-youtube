            "at": ""
          }
        }
      },
      "audio_file": "mp3/beat-B10.mp3",
      "actual_duration_s": 15.13,
      "build": {
        "status": "MANIM",
        "src": "manim/B10.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T12:12:16"
      }
    },
    {
      "beat_id": "B11",
      "t_start": 96.0,
      "estimated_duration_s": 9,
      "narration_text": "You cannot remove the zero-point energy by cooling. It is irreducible — not thermal, but structural. The confinement itself is the source.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "animate"

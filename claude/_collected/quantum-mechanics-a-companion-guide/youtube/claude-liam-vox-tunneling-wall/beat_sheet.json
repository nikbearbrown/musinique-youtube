    },
    {
      "beat_id": "B07",
      "t_start": 51,
      "estimated_duration_s": 13,
      "narration_text": "If the barrier is thin enough, some amplitude survives at the far side. That surviving tail launches an oscillating wave beyond the wall — a transmitted particle.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "accumulate"
      },
      "audio_file": "mp3/beat-B07.mp3",

    },
    {
      "beat_id": "B03",
      "t_start": 14,
      "estimated_duration_s": 9,
      "narration_text": "A quantum particle aimed at the same barrier sometimes appears on the other side. How does it get through a region it cannot enter?",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "hold"
      },
      "card": {
        "headline": "How does it get through?",
        "style": "question"

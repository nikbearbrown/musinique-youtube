        "at": "2026-07-18T12:34:14"
      }
    },
    {
      "beat_id": "B06",
      "t_start": 47,
      "estimated_duration_s": 4,
      "narration_text": "The mechanism: exponential decay through the barrier.",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "hold"
      },
      "card": {
        "headline": "The amplitude passes through — decaying exponentially.",

    },
    {
      "beat_id": "B14",
      "t_start": 129,
      "estimated_duration_s": 12,
      "narration_text": "What forces the statistics when electrons have no force between them? Antisymmetry writes a zero along the diagonal \u2014 they cannot share a point. One sign separates matter's structure from its collapse. QUANTUM MECHANICS.",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "hold"
      },
      "card": {
        "headline": "Antisymmetry writes the node. No force needed.",

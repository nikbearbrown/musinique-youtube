    },
    {
      "beat_id": "B12",
      "t_start": 105,
      "estimated_duration_s": 3,
      "narration_text": "The numbers: separation statistics.",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "hold"
      },
      "card": {
        "headline": "Worked example",
        "style": "example"
      },
      "audio_file": "../vox-exchange-stats/mp3/beat-B12.mp3",
      "actual_duration_s": 2.46,
      "locked": true,
      "source_clip": "../vox-exchange-stats/clips/B12.mp4",
      "source_audio": "../vox-exchange-stats/mp3/beat-B12.mp3"
    },
    {
      "beat_id": "B13",
      "t_start": 108,
      "estimated_duration_s": 21,
      "narration_text": "Two non-interacting particles in a 1D box, each in a different orbital. Distinguishable: \u27e8(x\u2081\u2212x\u2082)\u00b2\u27e9 = baseline. Fermions: baseline + exchange integral > baseline. Bosons: baseline \u2212 exchange integral < baseline. No Hamiltonian change \u2014 only the symmetry postulate.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "accumulate"
      },
      "audio_file": "../vox-exchange-stats/mp3/beat-B13.mp3",
      "actual_duration_s": 22.1,
      "locked": true,
      "source_clip": "../vox-exchange-stats/clips/B13.mp4",

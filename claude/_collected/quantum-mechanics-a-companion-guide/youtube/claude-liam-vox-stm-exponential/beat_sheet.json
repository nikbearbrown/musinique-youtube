    {
      "beat_id": "B02",
      "estimated_duration_s": 10,
      "narration_text": "A sharp conducting tip sits only a few ångströms above a conducting surface. Reduce the gap from five ångströms to four, and the measured current rises dramatically, although the tip moves less than an atom's width.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "approach"
      },
      "audio_file": "mp3/beat-B02.mp3",
      "actual_duration_s": 12.5,

      "beat_id": "B01",
      "estimated_duration_s": 9,
      "narration_text": "This is Liam, in for Bear. Double an alpha particle's energy, and a radioactive lifetime can collapse by roughly twenty-four orders of magnitude. The exponent does the damage.",
      "shot": {
        "type": "CARD",
        "source": "remotion",
        "motion": "hold",
        "remotion": {
          "pattern": "ClaudeComposerAsk",
          "provenance": "proven-core/ClaudeComposerAsk",
          "version": "1",
          "props": {
            "command": "How can roughly twice the alpha-decay energy mean about 10²⁴ times shorter lifetime?",
            "topic": "QUANTUM MECHANICS — ALPHA DECAY",
            "segment": "When a Small Energy Change Rewrites the Clock",
            "greeting": "Hallo, Liam",
            "runningText": "testing the tunneling exponent…",
            "output": [
              "Po-212: about 8.78 MeV and 0.3 microseconds.",
              "Th-232: about 4.01 MeV and 14 billion years."
            ],
            "folderLabel": "@NikBearBrown",

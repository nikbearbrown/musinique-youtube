          "props": {
            "command": "How can one sign separate Fermi–Dirac from Bose–Einstein statistics?",
            "topic": "QUANTUM MECHANICS — QUANTUM STATISTICS",
            "segment": "Why One Sign Splits the Universe in Two",
            "greeting": "Hallo, Liam",
            "runningText": "flipping the denominator…",
            "output": [

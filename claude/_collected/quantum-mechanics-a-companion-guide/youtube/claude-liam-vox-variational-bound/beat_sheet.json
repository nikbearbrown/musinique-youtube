      "beat_id": "B01",
      "estimated_duration_s": 9,
      "narration_text": "This is Liam, in for Bear. Choose any valid normalized trial state for a quantum Hamiltonian. Its average energy cannot lie below that Hamiltonian's true ground-state energy.",
      "shot": {
        "type": "CARD",
        "source": "remotion",
        "motion": "hold",
        "remotion": {
          "pattern": "ClaudeComposerAsk",
          "provenance": "proven-core/ClaudeComposerAsk",
          "version": "1",
          "props": {
            "command": "Why can a variational guess never fall below the exact ground-state energy?",
            "topic": "QUANTUM MECHANICS — VARIATIONAL PRINCIPLE",
            "segment": "Averages Cannot Beat Their Minimum",
            "greeting": "Hallo, Liam",
            "runningText": "expanding the trial state…",
            "output": [
              "Energy weights are nonnegative probabilities.",
              "A weighted average cannot lie below E₀."
            ],
            "folderLabel": "@NikBearBrown",
            "modelLabel": "Fable 5",
            "effortLabel": "High"
          },
          "rendered": {

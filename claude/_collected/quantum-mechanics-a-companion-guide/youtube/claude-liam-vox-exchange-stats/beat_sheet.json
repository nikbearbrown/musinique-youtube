    },
    {
      "beat_id": "B07",
      "t_start": 53,
      "estimated_duration_s": 12,
      "narration_text": "Bosons are symmetric — swap them, sign stays the same. Their diagonal becomes a ridge. Bosons bunch; fermions avoid. Opposite statistics from opposite signs.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "accumulate"
      },
      "audio_file": "mp3/beat-B07.mp3",
      "actual_duration_s": 9.77,

    },
    {
      "beat_id": "B08",
      "t_start": 65,
      "estimated_duration_s": 12,
      "narration_text": "With no interaction term turned on, fermions average a larger separation than distinguishable particles; bosons average a smaller one. The exchange correlation is real — only the symmetry creates it.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "accumulate"

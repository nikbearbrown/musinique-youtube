  "beats": [
    {
      "beat_id": "NBB00",
      "act": "COLD OPEN",
      "title": "Liam cold open — ClaudeComposerAsk",
      "engine": "kokoro",
      "voice": "am_onyx",
      "narration_text": "I finally understand why hydrogen's most-likely radius is one Bohr radius but its average is one-and-a-half — the radial probability multiplies the density by r-squared for the shell volume, and the long outer tail skews the mean past the peak. I want to actually compute this. Help me: (1) write the ground-state radial distribution and find where it peaks, (2) integrate to get the expectation value of r, (3) show how both numbers shift when we move to the 2s state.",
      "shot": {
        "type": "CARD",
        "source": "remotion",
        "motion": "hold",
        "remotion": {
          "pattern": "ClaudeComposerAsk",
          "provenance": "proven-core/ClaudeComposerAsk",
          "version": "1",
          "props": {
            "command": "I finally understand why hydrogen's most-likely radius is one Bohr radius but its average is one-and-a-half — the radial probability multiplies the density by r-squared for the shell volume, and the long outer tail skews the mean past the peak. I want to actually compute this. Help me: (1) write the ground-state radial distribution and find where it peaks, (2) integrate to get the expectation value of r, (3) show how both numbers shift when we move to the 2s state.",
            "topic": "QUANTUM MECHANICS",
            "segment": "",
            "greeting": "Your turn.",
            "runningText": "explaining the mechanism…",
            "output": [],
            "folderLabel": "@NikBearBrown",
            "modelLabel": "Fable 5",
            "effortLabel": "High"
          },
          "rendered": {
            "out": "media/NBB00.mp4",

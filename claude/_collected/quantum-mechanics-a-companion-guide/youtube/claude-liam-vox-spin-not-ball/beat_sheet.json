            "greeting": "Hallo, Liam",
            "runningText": "calculating the rim speed…",
            "output": [
              "Give the model every charitable assumption.",
              "It still demands about 170c at the equator."
            ],
            "folderLabel": "@NikBearBrown",
            "modelLabel": "Fable 5",
            "effortLabel": "High"
          }

  "beats": [
    {
      "beat_id": "NBB00",
      "act": "COLD OPEN",
      "title": "Liam cold open — ClaudeComposerAsk",
      "engine": "kokoro",
      "voice": "am_onyx",
      "narration_text": "I get that each photon carries h-nu and either clears sodium's work function or it doesn't, which is why dim ultraviolet beats intense red. I want to nail the arithmetic myself. Can you (1) compute sodium's threshold frequency and wavelength from its 2.28 eV work function, (2) show the maximum kinetic energy of an electron ejected by 400 nm light, and (3) explain why cranking red-light intensity up to a million photons still leaves the ammeter reading zero?",
      "shot": {
        "type": "CARD",
        "source": "remotion",
        "motion": "hold",
        "remotion": {
          "pattern": "ClaudeComposerAsk",
          "provenance": "proven-core/ClaudeComposerAsk",
          "version": "1",
          "props": {
            "command": "I get that each photon carries h-nu and either clears sodium's work function or it doesn't, which is why dim ultraviolet beats intense red. I want to nail the arithmetic myself. Can you (1) compute sodium's threshold frequency and wavelength from its 2.28 eV work function, (2) show the maximum kinetic energy of an electron ejected by 400 nm light, and (3) explain why cranking red-light intensity up to a million photons still leaves the ammeter reading zero?",
            "topic": "QUANTUM MECHANICS",
            "segment": "",
            "greeting": "Your turn.",
            "runningText": "explaining the mechanism…",
            "output": [],

        "at": "2026-07-18T14:11:05"
      }
    },
    {
      "beat_id": "B08",
      "estimated_duration_s": 11,
      "narration_text": "Watch the state character, not just the energy. The lower branch begins mostly blue and ends mostly red; the upper branch does the reverse. The states exchange identities through the mixing region.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "transform"
      },
      "audio_file": "mp3/beat-B08.mp3",
      "actual_duration_s": 11.31,
      "build": {
        "status": "MANIM",
        "src": "manim/B08.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T14:11:05"
      }
    },
    {
      "beat_id": "B09",
      "estimated_duration_s": 10,
      "narration_text": "Perturbation theory gives the same intuition: energy shifts contain a gap in the denominator, so nearby coupled levels influence one another much more strongly than distant ones.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "scale"
      },
      "audio_file": "mp3/beat-B09.mp3",
      "actual_duration_s": 10.5,
      "build": {
        "status": "MANIM",
        "src": "manim/B09.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T14:11:05"
      }
    },
    {
      "beat_id": "B10",
      "estimated_duration_s": 10,
      "narration_text": "Important exception: levels may cross exactly when their coupling is zero—for example, when symmetry places them in sectors that cannot mix.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "compare"
      },
      "audio_file": "mp3/beat-B10.mp3",
      "actual_duration_s": 8.49,

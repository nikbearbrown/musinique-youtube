        "filled_by": "manim",
        "at": "2026-07-18T14:11:05"
      }
    },
    {
      "beat_id": "B11",
      "estimated_duration_s": 10,
      "narration_text": "So the rule is conditional, not mystical: coupled levels repel; uncoupled levels may cross. The size of the avoided gap directly measures the coupling strength.",

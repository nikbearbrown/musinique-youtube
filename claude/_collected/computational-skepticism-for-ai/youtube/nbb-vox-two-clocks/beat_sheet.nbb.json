    {
      "beat_id": "B01",
      "act": "COLD OPEN",
      "estimated_duration_s": 4.0,
      "narration_text": "Why the study method that feels best teaches the least.",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "title"
      },
      "card": {
        "kind": "title",
        "copy": "Why the Study Method That Feels Best\nTeaches the Least"

          },
          "rendered": {
            "out": "media/B06.mp4",
            "at": ""
          }
        }
      },
      "image_description": "A student with a pencil working through a difficult problem on paper, looking focused and slightly frustrated, at a desk with an open textbook",
      "chosen_media": null,
      "actual_duration_s": 2.09,
      "audio_file": "../vox-two-clocks/mp3/beat-B06.mp3",
      "locked": true,
      "source_clip": "../vox-two-clocks/clips/B06.mp4",

      "source_audio": "../vox-calibration-curve/mp3/beat-B12.mp3"
    },
    {
      "beat_id": "B13",
      "act": "THE EXAMPLE",
      "estimated_duration_s": 18.0,
      "narration_text": "A medical risk model assigns ninety-nine percent confidence to four hundred patients. Count the outcomes: three hundred ten of those four hundred actually have the condition. That is seventy-seven percent, not ninety-nine. Every one of those four hundred cases, the model said essentially certain. Reality said less than four in five. The score was precise. It was also wrong.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "compare"
      },
      "scene_class": "B13_ExampleCalib",
      "audio_file": "../vox-calibration-curve/mp3/beat-B13.mp3",
      "actual_duration_s": 23.12,
      "locked": true,
      "source_clip": "../vox-calibration-curve/clips/B13.mp4",
      "source_audio": "../vox-calibration-curve/mp3/beat-B13.mp3"
    },

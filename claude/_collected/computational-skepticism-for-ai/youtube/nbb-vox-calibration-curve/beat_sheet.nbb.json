    },
    {
      "beat_id": "B12",
      "act": "THE IMPLICATION",
      "estimated_duration_s": 8.0,
      "narration_text": "A net will say ninety-nine percent when it should say eighty-five, and it will say it fluently.",
      "shot": {
        "type": "DOCUMENT",
        "source": "own",
        "motion": "highlight"
      },
      "scene_class": "B12_QuoteFluent",
      "actual_duration_s": 4.96,
      "audio_file": "../vox-calibration-curve/mp3/beat-B12.mp3",
      "locked": true,

      },
      "card": {
        "kind": "question",
        "copy": "If every agent passed validation,\nhow does the pipeline fail at 30%?"
      },
      "audio_file": "../vox-error-cascade/mp3/beat-B03.mp3",
      "actual_duration_s": 6.69,
      "locked": true,
      "source_clip": "../vox-error-cascade/clips/B03.mp4",

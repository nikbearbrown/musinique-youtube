    },
    {
      "beat_id": "B03",
      "act": "THE QUESTION",
      "estimated_duration_s": 7.0,
      "narration_text": "If every agent passed validation \u2014 each tested, each cleared \u2014 how does the pipeline fail at thirty percent?",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "question",

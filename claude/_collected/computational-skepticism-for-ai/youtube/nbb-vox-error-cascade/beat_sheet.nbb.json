    {
      "beat_id": "B02",
      "act": "COLD OPEN",
      "estimated_duration_s": 11.0,
      "narration_text": "Three agents, each tested and cleared. Agent A's error rate: one percent. Agent B: one percent. Agent C: one percent. The pipeline ships. The output is wrong. Not one-percent wrong. Thirty percent wrong. No individual agent was broken.",

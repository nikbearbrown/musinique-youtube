        "type": "GRAPHIC",
        "source": "remotion",
        "motion": "fade",
        "remotion": {
          "pattern": "NikBearBrownCodeBlock",
          "props": {
            "filename": "wacc_sim.py",
            "topic": "CORPORATE FINANCE",
            "segment": "WACC SENSITIVITY",
            "code": "import numpy as np\nnp.random.seed(42)\nn=10000\nRf=0.042; beta=1.1\nERP=np.random.uniform(0.045,0.060,n)\nWACC=Rf+beta*ERP*0.6+0.05*0.4\ng=0.025; FCFF=170\nTV=FCFF*(1+g)/(WACC-g)\nEV=sum(170/(1+WACC)**(i+1)\n    for i in range(5))+TV/(1+WACC)**5\np10,p90=np.percentile(WACC,[10,90])\nep10,ep90=np.percentile(EV,[10,90])\nprint(f\"WACC p10={p10*100:.1f}% p90={p90*100:.1f}%\")\nprint(f\"EV p10=${ep10:.0f}M p90=${ep90:.0f}M\")"
          },
          "rendered": {

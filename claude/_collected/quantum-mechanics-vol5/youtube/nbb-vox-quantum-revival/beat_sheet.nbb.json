    },
    {
      "beat_id": "B06",
      "act": "THE MECHANISM",
      "t_start": 52,
      "estimated_duration_s": 11,
      "narration_text": "At the revival time, every mode has completed an integer multiple of its cycle. They all return to exactly the phase they had at the start. The original shape snaps back.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "accumulate"
      },
      "audio_file": "../vox-quantum-revival/mp3/beat-B06.mp3",
      "actual_duration_s": 10.34,
      "locked": true,
      "source_clip": "../vox-quantum-revival/clips/B06.mp4",
      "source_audio": "../vox-quantum-revival/mp3/beat-B06.mp3"
    },
    {
      "beat_id": "B07",
      "act": "THE MECHANISM",
      "t_start": 63,
      "estimated_duration_s": 11,
      "narration_text": "The revival is not oscillation \u2014 it is constructive interference of many clocks all ticking at integer multiples of a base frequency. The box enforces commensurability.",

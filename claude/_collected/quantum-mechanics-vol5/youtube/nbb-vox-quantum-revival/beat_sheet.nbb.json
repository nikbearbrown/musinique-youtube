        "type": "CARD",
        "source": "own",
        "motion": "reveal"
      },
      "card": {
        "dek": "Modes dephase freely \u2014 no restoring force. Yet the original shape returns. Why?",
        "eyebrow": "THE QUESTION"
      },
      "audio_file": "../vox-quantum-revival/mp3/beat-B02.mp3",
      "actual_duration_s": 9.85,

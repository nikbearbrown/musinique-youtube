    {
      "beat_id": "B02",
      "act": "THE QUESTION",
      "t_start": 9,
      "estimated_duration_s": 10,
      "narration_text": "An initial wavefunction spreads into an incoherent smear. The modes are spinning at different rates. There is no restoring force. So why does the original shape come back?",

    {
      "beat_id": "B09",
      "act": "THE EXAMPLE",
      "t_start": 84,
      "estimated_duration_s": 14,
      "narration_text": "Illustrative: hydrogen ground state, energy minus 13.6 eV. The phasor sweeps at 2 times ten to the 16 radians per second. Probability density: one Bohr radius, locked still.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",

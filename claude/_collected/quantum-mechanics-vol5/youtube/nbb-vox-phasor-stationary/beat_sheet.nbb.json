    {
      "beat_id": "B10",
      "act": "RECAP",
      "t_start": 98,
      "estimated_duration_s": 9,
      "narration_text": "The phasor spins at unit length. Probability is the square of the modulus. A unit circle squared is one. Stationary means the observable is frozen, not the state.",
      "shot": {

    {
      "beat_id": "B09",
      "act": "THE EXAMPLE",
      "t_start": 83,
      "estimated_duration_s": 13,
      "narration_text": "Illustrative: a two-by-two matrix with eigenvalues 3 and minus 1. Apply it to a fan of eight arrows. Six fan away from their starting angles. Two stay on their own lines \u2014 one stretched by 3, one flipped and stretched.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "transform"
      },
      "audio_file": "../vox-eigen-directions/mp3/beat-B09.mp3",
      "actual_duration_s": 14.99,
      "locked": true,
      "source_clip": "../vox-eigen-directions/clips/B09.mp4",
      "source_audio": "../vox-eigen-directions/mp3/beat-B09.mp3"
    },
    {
      "beat_id": "B10",
      "act": "RECAP",
      "t_start": 96,
      "estimated_duration_s": 9,
      "narration_text": "A matrix rotates almost every arrow. The eigenvectors are the exceptions \u2014 only stretched, never turned. Every measurement outcome in quantum mechanics is one of these special directions.",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "reveal"
      },
      "card": {
        "dek": "Eigenvectors: invariant directions, only stretched. Measurement = projection onto one.",

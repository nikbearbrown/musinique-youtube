      "role": "CODE",
      "type": "SLATE",
      "narration": "Claude writes the scene. The slope m equals rise over run \u2014 here, 2 over 1. It also flags that perpendicular slopes multiply to negative one.",
      "estimated_duration_s": 14.0,
      "shot": {
        "source": null,
        "motion": "hold",
        "remotion": {
          "pattern": "NikBearBrownCodeBlock",
          "props": {
            "filename": "slope_viz.py",
            "segment": "LINEAR EQUATIONS",
            "topic": "COLLEGE ALGEBRA",
            "code": "# slope_viz.py \u2014 Claude Code output\nm = 2          # slope of main line\n# rise/run triangle from (0,1)\nrun = 1; rise = m * run   # rise = 2\n\n# parallel: same slope\nm_par = m     # m_par = 2\n\n# perpendicular: negative reciprocal\nm_perp = -1/m  # m_perp = -0.5\n\n# key rule: m1 * m2 = -1\nassert m * m_perp == -1"
          }
        }
      },
      "locked": true,

    {
      "beat_id": "B03",
      "role": "CODE",
      "type": "SLATE",
      "narration": "Claude writes the calculator. Annual gives twenty-five ninety-four. Daily gives twenty-seven eighteen. The marginal gain from daily to continuous is less than one dollar.",
      "estimated_duration_s": 14.0,
      "shot": {
        "source": null,
        "motion": "hold",
        "remotion": {
          "pattern": "NikBearBrownCodeBlock",
          "props": {
            "filename": "compound_calc.py",
            "segment": "COMPOUND INTEREST",
            "topic": "COLLEGE ALGEBRA",
            "code": "# compound_calc.py \u2014 Claude Code output\nimport math\nP=1000; r=0.10; t=10\n\nfor n, label in [(1,'annual'),(4,'quarterly'),\n                  (12,'monthly'),(365,'daily')]:\n    A = P * (1 + r/n)**(n*t)\n    print(f'n={n:4d} ({label:10s})  A=${A:,.2f}')\n\n# continuous\nA_c = P * math.exp(r*t)\nprint(f'n=inf (continuous)  A=${A_c:,.2f}')"
          }
        }
      },
      "locked": true,
      "source_clip": "../compound-interest-calculator/clips/B03.mp4",

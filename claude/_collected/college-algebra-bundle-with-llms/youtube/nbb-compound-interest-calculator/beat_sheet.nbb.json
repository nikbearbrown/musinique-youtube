            "command": "claude \"build compound interest calculator:\\n  P=1000, r=10%, t=10 years\\n  compare n=1 (annual), 4, 12, 365\\n  and continuous A=Pe^(rt)\"",
            "topic": "COLLEGE ALGEBRA",
            "segment": "COMPOUND INTEREST",
            "runningText": "calculating interest\u2026"
          }
        }
      },
      "locked": true,

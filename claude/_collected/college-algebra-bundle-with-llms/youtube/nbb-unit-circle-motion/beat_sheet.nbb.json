      "beat_id": "B03",
      "role": "CODE",
      "type": "SLATE",
      "narration": "Claude computes the coordinates. Cosine of forty-five degrees equals root two over two. Sine equals the same. The point on the circle is at root two over two, root two over two.",
      "estimated_duration_s": 14.0,
      "shot": {
        "source": null,
        "motion": "hold",
        "remotion": {
          "pattern": "NikBearBrownCodeBlock",
          "props": {
            "filename": "unit_circle.py",
            "segment": "TRIGONOMETRY",
            "topic": "COLLEGE ALGEBRA",
            "code": "# unit_circle.py \u2014 Claude Code output\nimport math\nR = 1.0\ntheta = math.pi / 4  # 45 degrees\n\n# point on unit circle\nx = R * math.cos(theta)  # sqrt(2)/2 \u2248 0.707\ny = R * math.sin(theta)  # sqrt(2)/2 \u2248 0.707\n\nprint(f'cos(45\u00b0) = {x:.4f} = sqrt(2)/2')\nprint(f'sin(45\u00b0) = {y:.4f} = sqrt(2)/2')\nprint(f'Point: ({x:.3f}, {y:.3f})')"
          }
        }
      },
      "locked": true,

            "topic": "COLLEGE ALGEBRA",
            "code": "# quad_ineq.py — Claude Code output\nimport sympy as sp\nx = sp.Symbol('x')\nexpr = x**2 - x - 6\nroots = sp.solve(expr, x)   # [-2, 3]\n\n# sign test at x=0 (between roots)\nval = expr.subs(x, 0)       # -6 < 0 ✓\n\n# solution\nprint(f'roots: {roots}')\nprint(f'solution: -2 < x < 3')\nprint(f'check x=0: {val} < 0 ✓')"

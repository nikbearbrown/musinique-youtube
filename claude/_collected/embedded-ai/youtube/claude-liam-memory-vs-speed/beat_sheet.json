    {
      "beat_id": "B01",
      "act": "NAIVE — STREAMING FROM DRAM",
      "narration_text": "Naive matrix multiply: for every output element, stream a full row from DRAM and a full column from DRAM. DRAM latency is around 200 cycles per fetch. The arithmetic unit sits idle waiting. The multiply count is correct; the memory access pattern is broken.",
      "shot": {
        "type": "GRAPHIC",
        "source": "manim",
        "motion": "compare",
        "manim": {
          "scene_file": "scenes.py",
          "scene_class": "B01_NaiveStream"

        "filled_by": "manim:B01_NaiveStream",
        "at": "2026-07-17T16:14:54"
      }
    },
    {
      "beat_id": "B02",
      "act": "TILED — RESIDENT IN CACHE",
      "narration_text": "Tiled multiply: load a block that fits in L1 cache. Reuse every element in that tile across many dot products before evicting it. Cache latency is 4 cycles. The same arithmetic now runs at near-peak speed because the data is always close.",
      "shot": {
        "type": "GRAPHIC",
        "source": "manim",
        "motion": "compare",
        "manim": {
          "scene_file": "scenes.py",
          "scene_class": "B02_TiledCache"
        }

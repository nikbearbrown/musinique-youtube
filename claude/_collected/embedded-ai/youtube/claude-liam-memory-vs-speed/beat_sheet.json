        "src": "manim/B02.mp4",
        "filled_by": "manim:B02_TiledCache",
        "at": "2026-07-17T16:14:54"
      }
    },
    {
      "beat_id": "B03",
      "act": "TIMING COMPARISON — 10X GAP",

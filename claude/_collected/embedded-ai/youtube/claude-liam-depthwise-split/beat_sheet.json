    },
    {
      "beat_id": "B02",
      "act": "SPLIT INTO DEPTHWISE AND POINTWISE",
      "narration_text": "Split it. First, depthwise: one 3-by-3 filter per channel, no mixing — 3 times 3 times 32 equals 288 MACs. Then pointwise: a 1-by-1 convolution mixes channels — 1 times 1 times 32 times 64 equals 2,048. Total: 2,336 MACs. The savings are in terracotta.",
      "shot": {
        "type": "GRAPHIC",
        "source": "manim",
        "motion": "split",
        "manim": {

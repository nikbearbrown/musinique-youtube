    {
      "beat_id": "B01",
      "act": "STANDARD CONV BLOCK",
      "narration_text": "Standard convolution: one 3-by-3 filter across 32 input channels to 64 output channels. That is 3 times 3 times 32 times 64 — 18,432 multiply-accumulate operations per pixel.",

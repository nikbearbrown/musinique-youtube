      }
    },
    {
      "beat_id": "B04",
      "act": "THE BASELINE",
      "estimated_duration_s": 11,
      "narration_text": "Start with a free electron. Its energy is h-bar squared k squared over two m: a smooth parabola with no gap.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "drawon"
      },
      "audio_file": "mp3/beat-B04.mp3",
      "actual_duration_s": 7.21,
      "build": {
        "status": "MANIM",

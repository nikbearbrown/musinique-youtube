    {
      "beat_id": "B02",
      "act": "COLD OPEN",
      "estimated_duration_s": 11,
      "narration_text": "The mechanism is surgical: Bragg coupling mixes waves with wave numbers plus pi over a and minus pi over a. Their sum and difference put probability density in different parts of the unit cell.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "split"
      },
      "audio_file": "mp3/beat-B02.mp3",

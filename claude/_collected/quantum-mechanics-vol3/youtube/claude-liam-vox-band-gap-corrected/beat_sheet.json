      }
    },
    {
      "beat_id": "B03",
      "act": "THE QUESTION",
      "estimated_duration_s": 8,
      "narration_text": "Why do two waves with the same free-particle energy split when a weak periodic potential is switched on?",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "hold",
        "remotion": {
          "pattern": "SlateCard",
          "props": {
            "eyebrow": "THE QUESTION",
            "topic": "QUANTUM MECHANICS",
            "headline": "Same free energy. Two standing waves. Why two crystal energies?"
          }
        }
      },
      "audio_file": "mp3/beat-B03.mp3",
      "actual_duration_s": 6.4,
      "build": {
        "status": "MANIM",

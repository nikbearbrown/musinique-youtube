    },
    {
      "beat_id": "B03",
      "act": "THE QUESTION",
      "t_start": 18,
      "estimated_duration_s": 9,
      "narration_text": "Perturbations point in all directions. Some should push energy up, some down. Yet every perturbation's second-order correction to the ground state is negative. Why?",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "hold",
        "remotion": {
          "pattern": "SlateCard",
          "provenance": "proven-core/SlateCard",
          "version": "1",
          "props": {
            "headline": "Perturbations point in all directions. Some should push energy up, some…",
            "eyebrow": "THE QUESTION",
            "topic": "QUANTUM MECHANICS"
          },
          "rendered": {
            "out": "media/B03.mp4",
            "at": ""
          }
        }
      },
      "card": {
        "eyebrow": "QUANTUM MECHANICS",
        "headline": "Any perturbation, any direction — always negative.",
        "dek": "Why does every second-order ground-state correction push energy down?"
      },
      "audio_file": "../vox-second-order-negative/mp3/beat-B03.mp3",
      "actual_duration_s": 10.06,
      "locked": true,
      "source_clip": "../vox-second-order-negative/clips/B03.mp4",

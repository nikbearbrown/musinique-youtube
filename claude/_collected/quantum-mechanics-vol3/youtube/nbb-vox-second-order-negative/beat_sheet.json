    {
      "beat_id": "B02",
      "act": "COLD OPEN",
      "t_start": 9,
      "estimated_duration_s": 9,
      "narration_text": "She tries a quartic bump. Negative. A random Hamiltonian she invented on the spot. Still negative. Every time, it pushes the ground state down.",

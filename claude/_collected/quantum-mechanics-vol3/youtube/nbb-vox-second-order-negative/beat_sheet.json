    },
    {
      "beat_id": "B07",
      "act": "THE MECHANISM",
      "t_start": 55,
      "estimated_duration_s": 10,
      "narration_text": "Here is every energy level in a quantum system. The ground state is at the bottom. Every other level sits above it. There are no levels below the ground state.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "drawon"
      },
      "audio_file": "../vox-second-order-negative/mp3/beat-B07.mp3",
      "actual_duration_s": 9.09,
      "locked": true,
      "source_clip": "../vox-second-order-negative/clips/B07.mp4",
      "source_audio": "../vox-second-order-negative/mp3/beat-B07.mp3"
    },
    {
      "beat_id": "B08",
      "act": "THE MECHANISM",
      "t_start": 65,
      "estimated_duration_s": 11,
      "narration_text": "Each term in the sum is a negative number — the squared matrix element divided by E₀ minus Eₙ. Negative divided by negative is positive... wait. No: squared magnitude divided by a negative denominator is negative.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "drawon"
      },
      "audio_file": "../vox-second-order-negative/mp3/beat-B08.mp3",
      "actual_duration_s": 14.29,
      "locked": true,
      "source_clip": "../vox-second-order-negative/clips/B08.mp4",

    },
    {
      "beat_id": "B09",
      "act": "THE MECHANISM",
      "t_start": 76,
      "estimated_duration_s": 10,
      "narration_text": "Every single term in the sum is a positive numerator over a negative denominator. The sum of all those terms is always negative — regardless of what the perturbation is.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "drawon"
      },
      "audio_file": "../vox-second-order-negative/mp3/beat-B09.mp3",
      "actual_duration_s": 9.56,
      "locked": true,
      "source_clip": "../vox-second-order-negative/clips/B09.mp4",

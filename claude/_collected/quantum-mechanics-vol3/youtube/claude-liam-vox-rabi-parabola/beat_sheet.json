    },
    {
      "beat_id": "B09",
      "act": "THE IMPLICATION",
      "t_start": 83,
      "estimated_duration_s": 10,
      "narration_text": "Rabi oscillations run every qubit, every NMR pulse, every trapped-ion gate. Perturbation theory is not wrong — it is valid only while Omega times t stays much less than one.",

        "needs": "PIPELINE → render animated_graphics.py scene B07_*"
      }
    },
    {
      "beat_id": "B08",
      "act": "THE IMPLICATION",
      "t_start": 73,
      "estimated_duration_s": 10,
      "narration_text": "Exactly at the first pi-pulse — where the atom fully flips — perturbation theory predicts 247 percent. The exact formula gives exactly 100 percent.",
      "shot": {
        "type": "GRAPHIC",
        "source": "manim",
        "motion": "drawon"
      },
      "audio_file": "mp3/beat-B08.mp3",

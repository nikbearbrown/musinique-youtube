          "props": {
            "headline": "The spins dispersed because they precessed at different rates. A pi-pulse\u2026",
            "eyebrow": "RECAP",
            "topic": "QUANTUM MECHANICS"
          },
          "rendered": {
            "out": "media/B11.mp4",

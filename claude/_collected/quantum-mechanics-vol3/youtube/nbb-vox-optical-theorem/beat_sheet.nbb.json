            "at": ""
          }
        }
      },
      "card": {
        "eyebrow": "QUANTUM MECHANICS",
        "headline": "\u03c3_tot = (4\u03c0/k) Im[f(0)]",
        "dek": "Blocking the beam requires forward scattering. The shadow counts \u2014 quantum cross-sections always exceed \u03c0a\u00b2."
      },

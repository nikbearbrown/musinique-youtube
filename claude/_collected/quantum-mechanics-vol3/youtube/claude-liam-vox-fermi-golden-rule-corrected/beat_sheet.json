    },
    {
      "beat_id": "B07",
      "act": "THE RATE",
      "estimated_duration_s": 13,
      "narration_text": "For weak coupling and a smooth continuum, summing those states gives the golden-rule rate: two pi over h-bar times the matrix element squared times the density of final states at the matching energy.",

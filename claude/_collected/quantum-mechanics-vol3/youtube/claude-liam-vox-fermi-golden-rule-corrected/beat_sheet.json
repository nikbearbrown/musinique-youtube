    },
    {
      "beat_id": "B06",
      "act": "FINITE TIME",
      "estimated_duration_s": 11,
      "narration_text": "A finite observation time gives each transition a sinc-squared energy window. As time grows, that window narrows while its area grows linearly, selecting energy-conserving final states.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "narrow"

    {
      "beat_id": "B03",
      "act": "THE QUESTION",
      "estimated_duration_s": 9,
      "narration_text": "Where did the oscillation go? Which assumptions turn a reversible many-state problem into a constant golden-rule rate and an exponential lifetime?",

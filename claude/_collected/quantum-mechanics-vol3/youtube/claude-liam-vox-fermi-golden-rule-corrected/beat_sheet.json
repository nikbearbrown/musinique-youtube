    {
      "beat_id": "B04",
      "act": "ONE FINAL STATE",
      "estimated_duration_s": 10,
      "narration_text": "With one sharply selected final state, coherent amplitude has a well-defined route out and a well-defined route back. The two-state problem retains phase and can oscillate.",

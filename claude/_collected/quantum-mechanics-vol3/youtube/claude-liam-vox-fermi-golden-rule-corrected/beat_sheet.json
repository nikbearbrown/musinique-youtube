    },
    {
      "beat_id": "B05",
      "act": "MANY FINAL STATES",
      "estimated_duration_s": 11,
      "narration_text": "Now couple to many nearby energies. Their transition amplitudes begin together but rotate at different detunings. The outgoing pieces spread around the complex plane and cease to add coherently back into the source.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "dephase"

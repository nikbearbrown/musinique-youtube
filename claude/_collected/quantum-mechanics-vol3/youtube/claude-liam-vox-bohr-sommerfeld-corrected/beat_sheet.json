    {
      "beat_id": "B02",
      "act": "THE PICTURE",
      "estimated_duration_s": 11,
      "narration_text": "In semiclassical quantization, a sequence of these classical ellipses represents allowed energies. This is a visualization of energy shells, not a claim that a quantum particle follows a definite phase-space orbit.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "accumulate"
      },
      "audio_file": "mp3/beat-B02.mp3",
      "build": {

      }
    },
    {
      "beat_id": "B11",
      "act": "UNCERTAINTY",
      "estimated_duration_s": 11,
      "narration_text": "For the oscillator, shrinking both position and momentum spreads to zero would violate their uncertainty relation. Balancing kinetic and potential costs leaves a minimum energy.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "balance"

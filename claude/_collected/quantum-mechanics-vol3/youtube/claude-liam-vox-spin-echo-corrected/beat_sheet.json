    {
      "beat_id": "B04",
      "act": "STATIC OFFSETS",
      "estimated_duration_s": 11,
      "narration_text": "Let each spin have angular frequency omega zero plus a fixed offset delta omega. During the first wait, its extra phase becomes delta omega times tau.",

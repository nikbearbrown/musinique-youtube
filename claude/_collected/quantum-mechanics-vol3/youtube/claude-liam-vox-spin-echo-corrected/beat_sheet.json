    {
      "beat_id": "B07",
      "act": "REPHASING",
      "estimated_duration_s": 11,
      "narration_text": "The frequency offsets do not change. Fast spins are still fast, but now they start behind; slow spins start ahead. A second interval tau cancels the first accumulated offset phase.",

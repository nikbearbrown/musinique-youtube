    {
      "beat_id": "B09",
      "act": "APPLICATION",
      "estimated_duration_s": 12,
      "narration_text": "Spin echoes are used in NMR and many MRI sequences to separate static inhomogeneity from more persistent transverse decay. Actual imaging also depends on gradients, timing, contrast design, and reconstruction.",

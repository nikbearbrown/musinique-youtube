    {
      "beat_id": "B05",
      "act": "DEPHASING",
      "estimated_duration_s": 11,
      "narration_text": "Positive offsets move ahead; negative offsets fall behind. The individual transverse moments remain, but their vector sum shrinks. This reversible inhomogeneous broadening contributes to T two star.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "spread"

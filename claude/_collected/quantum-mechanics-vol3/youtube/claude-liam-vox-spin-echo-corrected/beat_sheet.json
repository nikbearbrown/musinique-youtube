    {
      "beat_id": "B08",
      "act": "WHAT REMAINS",
      "estimated_duration_s": 13,
      "narration_text": "Ideal static offsets refocus. Irreversible transverse relaxation, time-varying noise, diffusion through gradients, and pulse imperfections reduce the echo. In a simple Hahn experiment the envelope is often modeled as e to minus two tau over T two.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "decay"

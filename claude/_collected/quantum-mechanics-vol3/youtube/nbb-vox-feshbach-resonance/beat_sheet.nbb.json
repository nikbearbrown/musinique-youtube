    {
      "beat_id": "B11",
      "act": "THE IMPLICATION",
      "t_start": 96,
      "estimated_duration_s": 10,
      "narration_text": "A Feshbach resonance uses a magnetic field to tune the bound-state energy across threshold. That gives experimenters a dial to set the scattering length \u2014 from near zero to plus or minus infinity.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "drawon"

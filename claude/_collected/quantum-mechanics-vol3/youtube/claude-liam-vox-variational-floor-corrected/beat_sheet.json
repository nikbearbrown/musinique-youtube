      "beat_id": "B01",
      "act": "COLD OPEN",
      "estimated_duration_s": 11,
      "narration_text": "This is Liam, in for Bear. Choose any normalized trial state in the Hamiltonian’s domain. Its energy expectation cannot lie below the bottom of that Hamiltonian’s spectrum.",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "hold",
        "remotion": {
          "pattern": "ClaudeComposerAsk",
          "props": {
            "command": "Why can a valid trial state never beat the ground energy?",
            "topic": "QUANTUM MECHANICS — VARIATIONAL PRINCIPLE",
            "segment": "Why You Cannot Dig Below the Ground State",
            "greeting": "Hola, Bear",
            "runningText": "expanding the trial state in energy eigenstates…",
            "output": [
              "The expectation is a nonnegative weighted average.",
              "No weighted average can undercut its lowest ingredient."
            ],
            "folderLabel": "@NikBearBrown",

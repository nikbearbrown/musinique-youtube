    {
      "beat_id": "B07",
      "act": "EXTINCTION PARADOX",
      "estimated_duration_s": 11,
      "narration_text": "That narrow forward contribution integrates to another pi a squared. Add diffraction to geometric scattering and the hard-sphere total approaches two pi a squared: the extinction paradox.",

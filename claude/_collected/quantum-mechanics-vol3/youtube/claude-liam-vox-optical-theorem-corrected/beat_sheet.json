    {
      "beat_id": "B08",
      "act": "OPTICAL THEOREM",
      "estimated_duration_s": 13,
      "narration_text": "The optical theorem encodes flux conservation: total cross-section equals four pi over k times the imaginary part of the forward elastic amplitude. With open inelastic channels, total means elastic plus reaction loss.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "write"
      },
      "audio_file": "mp3/beat-B08.mp3",
      "actual_duration_s": 13.95,

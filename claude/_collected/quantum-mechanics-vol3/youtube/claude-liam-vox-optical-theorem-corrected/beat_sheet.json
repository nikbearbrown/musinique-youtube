    },
    {
      "beat_id": "B10",
      "act": "THE EXAMPLE",
      "estimated_duration_s": 12,
      "narration_text": "Let a equal two angstroms. Four pi a squared is about five point zero times ten to the minus nineteen square meters. The high-energy limit, two pi a squared, is about two point five times ten to the minus nineteen.",

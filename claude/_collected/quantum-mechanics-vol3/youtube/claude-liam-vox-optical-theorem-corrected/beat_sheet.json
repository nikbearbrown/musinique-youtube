    {
      "beat_id": "B04",
      "act": "THE PROBLEM",
      "estimated_duration_s": 10,
      "narration_text": "A ray either hits the disk or misses it. A wave has no such binary trajectory: it diffracts, interferes, and redistributes flux over angle.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "spread"
      },
      "audio_file": "mp3/beat-B04.mp3",

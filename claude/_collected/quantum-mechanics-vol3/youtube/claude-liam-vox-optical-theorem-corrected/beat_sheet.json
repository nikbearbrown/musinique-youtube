        "filled_by": "manim",
        "at": "2026-07-18T19:26:10"
      }
    },
    {
      "beat_id": "B09",
      "act": "SCOPE",
      "estimated_duration_s": 12,
      "narration_text": "Do not turn this hard-sphere result into a universal bound. Other potentials can become nearly transparent at selected energies, as in Ramsauer-Townsend scattering. Coulomb's long range also needs special treatment.",

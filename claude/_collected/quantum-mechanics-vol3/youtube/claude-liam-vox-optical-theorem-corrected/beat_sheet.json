    },
    {
      "beat_id": "B06",
      "act": "HIGH ENERGY",
      "estimated_duration_s": 11,
      "narration_text": "When k a is large, many partial waves participate. Geometric deflection contributes roughly pi a squared, but the blocked beam also demands a coherent forward diffraction pattern.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "interfere"

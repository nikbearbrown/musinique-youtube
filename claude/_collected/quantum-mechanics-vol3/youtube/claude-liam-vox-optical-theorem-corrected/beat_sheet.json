    },
    {
      "beat_id": "B05",
      "act": "LOW ENERGY",
      "estimated_duration_s": 12,
      "narration_text": "When k a is much less than one, only the s wave matters. A hard sphere has scattering length a, so its nearly isotropic amplitude has magnitude a and the integrated cross-section is four pi a squared.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "radiate"
      },
      "audio_file": "mp3/beat-B05.mp3",
      "actual_duration_s": 12.03,

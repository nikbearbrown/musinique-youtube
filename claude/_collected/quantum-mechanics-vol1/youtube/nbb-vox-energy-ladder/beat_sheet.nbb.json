      "actual_duration_s": 13.89,
      "locked": true,
      "source_clip": "../vox-energy-ladder/clips/B02.mp4",
      "source_audio": "../vox-energy-ladder/mp3/beat-B02.mp3"
    },
    {
      "beat_id": "B03",
      "t_start": 19.0,
      "estimated_duration_s": 10.0,
      "narration_text": "Every smooth potential looks like a parabola near its bottom. Quantum mechanics restricts the energy of anything trapped in a parabola to a staircase of levels. How does a smooth curve force discrete steps?",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "hold"
      },
      "card": {
        "kind": "question",
        "copy": "Any smooth trap looks like a parabola near its bottom.\nEnergy is restricted to discrete rungs.\nHow does a smooth curve force a staircase?",

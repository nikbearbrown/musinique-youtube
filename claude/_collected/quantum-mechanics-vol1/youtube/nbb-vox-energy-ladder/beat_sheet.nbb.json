    {
      "beat_id": "B02",
      "t_start": 9.0,
      "estimated_duration_s": 10.0,
      "narration_text": "Classically a spring oscillator can have any energy \u2014 slow and gentle, or fast and wild, with a continuous range between. Quantum mechanics says no. Measure the energy and you always land on a discrete rung.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "compare"
      },
      "graphic": {
        "manim": "B02_ClassicalVsQuantum"
      },

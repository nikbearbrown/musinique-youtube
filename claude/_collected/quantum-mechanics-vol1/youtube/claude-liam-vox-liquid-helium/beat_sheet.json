  "beats": [
    {
      "beat_id": "B01",
      "estimated_duration_s": 11,
      "narration_text": "This is Liam, in for Bear. Cool helium-four at ordinary pressure toward absolute zero and it still does not crystallize. To make it solid, you must also apply roughly twenty-five bar. What keeps the atoms from settling?",
      "shot": {
        "type": "CARD",
        "source": "remotion",
        "motion": "hold",
        "remotion": {
          "pattern": "ClaudeComposerAsk",
          "provenance": "proven-core/ClaudeComposerAsk",
          "version": "1",
          "props": {
            "command": "Why does helium-4 remain liquid near absolute zero at low pressure, yet freeze when compressed above roughly 25 bar?",
            "topic": "QUANTUM MECHANICS — ZERO-POINT MOTION",
            "segment": "The Liquid That Will Not Settle",
            "greeting": "Hallo, Liam",
            "runningText": "balancing binding against quantum delocalization…",
            "output": [
              "Cooling removes thermal agitation, not zero-point motion.",
              "Helium atoms are light and weakly bound."
            ],
            "folderLabel": "@NikBearBrown",
            "modelLabel": "Fable 5",
            "effortLabel": "High"
          },
          "rendered": {
            "out": "media/B01.mp4",

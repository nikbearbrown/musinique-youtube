    {
      "beat_id": "B03",
      "t_start": 19.0,
      "estimated_duration_s": 9.0,
      "narration_text": "The current is flowing across a vacuum gap. Classically, electrons can't cross a gap wider than their energy allows. So why does any current flow at all?",

        "src": "manim/B11.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:06:26"
      }
    },
    {
      "beat_id": "B12",
      "estimated_duration_s": 8,
      "narration_text": "Quantum mechanics still applies. Human momentum compresses the matter wavelength so drastically that a doorway is, in wave terms, unimaginably wide.",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "hold"

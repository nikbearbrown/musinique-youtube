      }
    },
    {
      "beat_id": "B03",
      "estimated_duration_s": 6,
      "narration_text": "How can two reflecting boundaries produce no reflection at all?",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "hold"
      },
      "audio_file": "mp3/beat-B03.mp3",

        "at": "2026-07-18T15:43:11"
      }
    },
    {
      "beat_id": "B04",
      "estimated_duration_s": 11,
      "narration_text": "At the first boundary, one reflected amplitude leaves immediately. Another part enters, reflects from the second boundary, and later returns through the first.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "split"

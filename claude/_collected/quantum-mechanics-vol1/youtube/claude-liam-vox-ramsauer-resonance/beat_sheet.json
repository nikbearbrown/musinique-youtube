    {
      "beat_id": "B02",
      "estimated_duration_s": 10,
      "narration_text": "Assume the particle energy is above the rectangular barrier. The wave propagates in every region, but its wave number changes inside, so each boundary normally reflects part of it.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "compare"

        "at": "2026-07-18T15:43:11"
      }
    },
    {
      "beat_id": "B08",
      "estimated_duration_s": 10,
      "narration_text": "At that resonance, reflected probability falls to zero and transmission reaches one in the ideal one-dimensional model, despite the potential still being present.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "morph"
      },
      "audio_file": "mp3/beat-B08.mp3",

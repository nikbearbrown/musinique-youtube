        "status": "MANIM",
        "src": "manim/B07.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:21:20"
      }
    },
    {
      "beat_id": "B08",
      "estimated_duration_s": 9,
      "narration_text": "It remains minimum uncertainty: sigma x times sigma p equals h bar over two at every time.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "hold"
      },
      "audio_file": "mp3/beat-B08.mp3",
      "actual_duration_s": 6.59,

      }
    },
    {
      "beat_id": "B03",
      "estimated_duration_s": 7,
      "narration_text": "Now place a Gaussian with exactly the oscillator ground-state width inside a parabolic potential.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "compare"
      },
      "audio_file": "mp3/beat-B03.mp3",

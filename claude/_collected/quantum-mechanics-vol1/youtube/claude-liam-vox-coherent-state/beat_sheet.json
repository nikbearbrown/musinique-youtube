      }
    },
    {
      "beat_id": "B04",
      "estimated_duration_s": 10,
      "narration_text": "Its center obeys the classical equation: x center double dot plus omega squared x center equals zero. So the center follows a cosine at frequency omega.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "derive"
      },
      "audio_file": "mp3/beat-B04.mp3",
      "actual_duration_s": 10.11,

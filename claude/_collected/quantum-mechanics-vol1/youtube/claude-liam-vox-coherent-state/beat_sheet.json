        "status": "MANIM",
        "src": "manim/B08.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:21:20"
      }
    },
    {
      "beat_id": "B09",
      "estimated_duration_s": 10,
      "narration_text": "A squeezed Gaussian is different. Its uncertainty patch is elliptical, so phase-space rotation makes the position width breathe even in the same harmonic well.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "rotate"
      },
      "audio_file": "mp3/beat-B09.mp3",
      "actual_duration_s": 9.39,

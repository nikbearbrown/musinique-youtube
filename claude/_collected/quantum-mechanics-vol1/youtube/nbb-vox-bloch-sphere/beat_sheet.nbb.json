    {
      "beat_id": "B05",
      "t_start": 38.0,
      "estimated_duration_s": 10.0,
      "narration_text": "The north pole is theta equals zero: pure spin-up. The south pole is theta equals pi: pure spin-down. The entire equator is where theta equals pi over two \u2014 equal superpositions, differing only in relative phase.",

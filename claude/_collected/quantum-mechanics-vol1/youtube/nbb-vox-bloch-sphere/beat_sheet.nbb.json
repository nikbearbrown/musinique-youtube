    {
      "beat_id": "B02",
      "t_start": 9.0,
      "estimated_duration_s": 10.0,
      "narration_text": "A qubit state has two complex amplitudes. That seems like four real parameters. But normalization fixes one, and a global phase is unobservable. That removes two more. Two real numbers remain \u2014 exactly the two angles needed to point to a spot on a sphere.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "compare"
      },
      "graphic": {
        "manim": "B02_ParameterCount"

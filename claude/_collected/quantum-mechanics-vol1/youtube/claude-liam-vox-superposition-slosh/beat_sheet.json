          "props": {
            "command": "Why can two stationary energy states combine into a moving probability density?",
            "topic": "QUANTUM MECHANICS — SUPERPOSITION BEATS",
            "segment": "Motion from Relative Phase",
            "greeting": "Hallo, Liam",
            "runningText": "expanding the interference term…",
            "output": [

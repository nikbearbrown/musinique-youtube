  "beats": [
    {
      "beat_id": "B01",
      "estimated_duration_s": 11,
      "narration_text": "This is Liam, in for Bear. Release a Gaussian matter-wave packet and it broadens. Look inside its carrier wave later: crests bunch at the front and stretch at the back. The packet has acquired a chirp. Why?",
      "shot": {
        "type": "CARD",
        "source": "remotion",
        "motion": "hold",
        "remotion": {
          "pattern": "ClaudeComposerAsk",
          "provenance": "proven-core/ClaudeComposerAsk",
          "version": "1",
          "props": {
            "command": "Why does a freely spreading quantum Gaussian develop a position-dependent local wavenumber even though its momentum distribution is conserved?",
            "topic": "QUANTUM MECHANICS — WAVE PACKETS",
            "segment": "The Phase Gradient Inside a Spreading Packet",
            "greeting": "Hallo, Liam",
            "runningText": "sorting Fourier components by velocity…",
            "output": [
              "Free evolution preserves momentum weights.",
              "Dispersion builds position-momentum correlation."
            ],
            "folderLabel": "@NikBearBrown",
            "modelLabel": "Fable 5",
            "effortLabel": "High"
          },
          "rendered": {
            "out": "media/B01.mp4",
            "at": ""
          }
        }
      },
      "audio_file": "mp3/beat-B01.mp3",
      "actual_duration_s": 11.37,
      "build": {
        "status": "VIDEO",
        "src": "media/B01.mp4",
        "filled_by": "media",
        "at": "2026-07-18T16:54:12"
      }
    },
    {
      "beat_id": "B02",
      "estimated_duration_s": 9,
      "narration_text": "At release, take a Gaussian envelope multiplying a carrier with central wavenumber k zero. Its phase gradient is initially uniform across the envelope.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "reveal"
      },
      "audio_file": "mp3/beat-B02.mp3",
      "actual_duration_s": 9.54,
      "build": {
        "status": "MANIM",
        "src": "manim/B02.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:54:12"
      }
    },
    {
      "beat_id": "B03",
      "estimated_duration_s": 9,
      "narration_text": "The packet is a superposition of nearby Fourier components. Their amplitudes in momentum space remain fixed during free evolution; only their phases change.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "decompose"
      },
      "audio_file": "mp3/beat-B03.mp3",
      "actual_duration_s": 9.71,
      "build": {
        "status": "MANIM",
        "src": "manim/B03.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:54:12"
      }
    },
    {
      "beat_id": "B04",
      "estimated_duration_s": 9,
      "narration_text": "For a nonrelativistic free particle, omega equals h bar k squared over two m. Group velocity is h bar k over m, so larger k travels faster.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "derive"
      },
      "audio_file": "mp3/beat-B04.mp3",
      "actual_duration_s": 10.2,
      "build": {
        "status": "MANIM",
        "src": "manim/B04.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:54:12"
      }
    },
    {
      "beat_id": "B05",
      "estimated_duration_s": 9,
      "narration_text": "As time passes, high-k components become enriched toward the leading side while low-k components lag toward the trailing side.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "sort"
      },
      "audio_file": "mp3/beat-B05.mp3",
      "actual_duration_s": 7.66,
      "build": {
        "status": "MANIM",
        "src": "manim/B05.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:54:12"
      }
    },
    {
      "beat_id": "B06",
      "estimated_duration_s": 9,
      "narration_text": "This sorting is a correlation, not a change in the overall momentum histogram. The same k values remain, but position now tells you something about which ones dominate locally.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "compare"
      },
      "audio_file": "mp3/beat-B06.mp3",
      "actual_duration_s": 11.09,
      "build": {
        "status": "MANIM",
        "src": "manim/B06.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:54:12"
      }
    },
    {
      "beat_id": "B07",
      "estimated_duration_s": 10,
      "narration_text": "The evolved Gaussian carries a quadratic phase across its envelope. Differentiate that phase with position and the local wavenumber becomes a linear ramp.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "derive"
      },
      "audio_file": "mp3/beat-B07.mp3",
      "actual_duration_s": 9.13,
      "build": {
        "status": "MANIM",
        "src": "manim/B07.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:54:12"
      }
    },
    {
      "beat_id": "B08",
      "estimated_duration_s": 9,
      "narration_text": "Write it schematically as k local equals k zero plus C of t times x minus x center. For positive time, C is positive.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "plot"
      },
      "audio_file": "mp3/beat-B08.mp3",
      "actual_duration_s": 8.53,
      "build": {
        "status": "MANIM",
        "src": "manim/B08.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:54:12"
      }
    },
    {
      "beat_id": "B09",
      "estimated_duration_s": 9,
      "narration_text": "So behind the center, local k is lower and the wavelength is longer. Ahead of the center, local k is higher and the wavelength is shorter.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "compare"
      },
      "audio_file": "mp3/beat-B09.mp3",
      "actual_duration_s": 8.09,
      "build": {
        "status": "MANIM",
        "src": "manim/B09.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:54:12"
      }
    },
    {
      "beat_id": "B10",
      "estimated_duration_s": 9,
      "narration_text": "At the far tails, amplitude is tiny, so a local wavelength there has little experimental weight. The visible chirp matters where the envelope remains appreciable.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "qualify"
      },
      "audio_file": "mp3/beat-B10.mp3",
      "actual_duration_s": 9.51,
      "build": {
        "status": "MANIM",
        "src": "manim/B10.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:54:12"
      }
    },
    {
      "beat_id": "B11",
      "estimated_duration_s": 9,
      "narration_text": "Reverse the evolution mathematically and the phase correlation reverses. Interactions or lenses can also add, remove, or invert chirp, but free spreading creates this positive ramp.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "reverse"
      },
      "audio_file": "mp3/beat-B11.mp3",
      "actual_duration_s": 10.99,
      "build": {
        "status": "MANIM",
        "src": "manim/B11.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:54:12"
      }
    },
    {
      "beat_id": "B12",
      "estimated_duration_s": 8,
      "narration_text": "The packet does not manufacture momentum. Quadratic dispersion sorts its existing components in space, turning a uniform phase slope into a chirped one.",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "hold"
      },
      "audio_file": "mp3/beat-B12.mp3",
      "actual_duration_s": 9.51,
      "build": {
        "status": "MANIM",
        "src": "manim/B12.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:54:12"
      }
    },
    {
      "beat_id": "B13",
      "estimated_duration_s": 9,
      "narration_text": "Your turn. If the local phase is k zero x plus b x squared, differentiate it and identify the local wavenumber.",

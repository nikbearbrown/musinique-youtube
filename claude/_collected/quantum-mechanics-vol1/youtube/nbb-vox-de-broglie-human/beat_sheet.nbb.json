    {
      "beat_id": "B03",
      "t_start": 19.0,
      "estimated_duration_s": 9.0,
      "narration_text": "An electron at fifty-four electron-volts has wavelength 0.167 nanometers \u2014 comparable to atom spacing. Diffraction happens. Why not for you?",

    {
      "beat_id": "B02",
      "t_start": 9.0,
      "estimated_duration_s": 10.0,
      "narration_text": "The 48 iron atoms form a ring about 7 nanometers across. They are not a source of electrons. They are a wall. The electrons on the copper surface move freely \u2014 until they hit this wall. And then the wave bounces back.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "compare"
      },
      "graphic": {
        "manim": "B02_CorralSetup"

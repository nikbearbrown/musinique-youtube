      "locked": true,
      "source_clip": "../vox-quantum-corral/clips/B02.mp4",
      "source_audio": "../vox-quantum-corral/mp3/beat-B02.mp3"
    },
    {
      "beat_id": "B03",
      "t_start": 19.0,
      "estimated_duration_s": 9.0,
      "narration_text": "Classical electrons in a circular pen would distribute smoothly. The STM image shows sharp rings at fixed radii. These rings were not placed. They appeared from confinement alone. Where do they come from?",

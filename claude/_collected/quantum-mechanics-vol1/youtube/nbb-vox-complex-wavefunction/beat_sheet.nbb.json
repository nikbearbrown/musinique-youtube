    {
      "beat_id": "B02",
      "t_start": 9.0,
      "estimated_duration_s": 10.0,
      "narration_text": "Measure the probability density of an electron moving right, then one moving left at the same speed. The histograms match exactly \u2014 both are the same Gaussian hump.",

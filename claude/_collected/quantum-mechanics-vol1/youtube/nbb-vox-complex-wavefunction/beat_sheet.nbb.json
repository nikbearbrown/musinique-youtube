    {
      "beat_id": "B03",
      "t_start": 19.0,
      "estimated_duration_s": 10.0,
      "narration_text": "Classical physics says position tells you everything. But these two particles are different \u2014 one is racing right, the other left. The probability density is blind to that.",
      "shot": {
        "type": "CARD",
        "source": "own",
        "motion": "hold"
      },
      "card": {
        "kind": "question",
        "copy": "Two identical probability humps. One moves right, one moves left. How does the wave function know which is which?",
        "sub": "QUANTUM MECHANICS"
      },

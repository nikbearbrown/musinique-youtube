    {
      "beat_id": "B04",
      "t_start": 29.0,
      "estimated_duration_s": 10.0,
      "narration_text": "The wave function is a complex number at every point \u2014 a length and a direction. If you plot the real and imaginary parts as a helix in space, the helix winds clockwise for rightward motion and counterclockwise for leftward motion.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "rotate"
      },
      "graphic": {

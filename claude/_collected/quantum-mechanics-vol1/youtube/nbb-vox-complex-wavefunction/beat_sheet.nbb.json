    {
      "beat_id": "B08",
      "t_start": 70.0,
      "estimated_duration_s": 10.0,
      "narration_text": "This is why the Schrodinger equation uses i on the left side \u2014 it needs to distinguish future from past and right-mover from left-mover. Without i, time evolution would be symmetric forward and backward and every moving state would be its own mirror image.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "compare"

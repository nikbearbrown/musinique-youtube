        "at": "2026-07-18T16:35:44"
      }
    },
    {
      "beat_id": "B10",
      "estimated_duration_s": 9,
      "narration_text": "So the famous image is not a photograph of forty-eight electrons orbiting. It is a spatial map of energy-resolved surface-state interference.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "qualify"

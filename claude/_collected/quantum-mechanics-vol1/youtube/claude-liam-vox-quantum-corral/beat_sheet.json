    },
    {
      "beat_id": "B02",
      "estimated_duration_s": 9,
      "narration_text": "The copper one-one-one surface supports electrons that move approximately as a two-dimensional wave gas along the surface.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "flow"
      },
      "audio_file": "mp3/beat-B02.mp3",
      "actual_duration_s": 7.72,
      "build": {
        "status": "MANIM",
        "src": "manim/B02.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:35:44"
      }
    },
    {
      "beat_id": "B03",
      "estimated_duration_s": 9,
      "narration_text": "Each iron adatom is a strong scatterer. Forty-eight of them form a circular barrier, but not an ideal impenetrable wall.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "accumulate"
      },
      "audio_file": "mp3/beat-B03.mp3",
      "actual_duration_s": 7.62,
      "build": {
        "status": "MANIM",
        "src": "manim/B03.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:35:44"
      }
    },
    {
      "beat_id": "B04",
      "estimated_duration_s": 10,
      "narration_text": "A surface electron wave travels outward, scatters from the ring, and returns. The outgoing and returning amplitudes add or cancel according to phase.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "reflect"
      },
      "audio_file": "mp3/beat-B04.mp3",
      "actual_duration_s": 9.49,
      "build": {
        "status": "MANIM",
        "src": "manim/B04.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:35:44"
      }
    },
    {
      "beat_id": "B05",
      "estimated_duration_s": 9,
      "narration_text": "Constructive interference produces bright probability-amplitude bands. Destructive interference produces dark nodes between them.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "interfere"
      },
      "audio_file": "mp3/beat-B05.mp3",
      "actual_duration_s": 7.7,
      "build": {
        "status": "MANIM",
        "src": "manim/B05.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:35:44"
      }
    },
    {
      "beat_id": "B06",
      "estimated_duration_s": 10,
      "narration_text": "Only wave patterns compatible with the circular confinement build up strongly. The boundary turns a continuum into a set of resonant spatial modes.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "select"
      },
      "audio_file": "mp3/beat-B06.mp3",
      "actual_duration_s": 9.0,
      "build": {
        "status": "MANIM",
        "src": "manim/B06.mp4",
        "filled_by": "manim",
        "at": "2026-07-18T16:35:44"
      }
    },
    {
      "beat_id": "B07",
      "estimated_duration_s": 9,
      "narration_text": "For rotationally symmetric modes, the maxima and nodes are circles. Other allowed modes can carry angular lobes instead of perfect rings.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "compare"
      },
      "audio_file": "mp3/beat-B07.mp3",
      "actual_duration_s": 8.55,

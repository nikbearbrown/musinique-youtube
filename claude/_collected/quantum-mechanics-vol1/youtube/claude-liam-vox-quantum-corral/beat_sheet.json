        "filled_by": "manim",
        "at": "2026-07-18T16:35:44"
      }
    },
    {
      "beat_id": "B09",
      "estimated_duration_s": 10,
      "narration_text": "The scanning tunneling microscope measures tunneling conductance at a chosen position and bias. That signal tracks the local density of available electronic states near that energy.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "scan"
      },
      "audio_file": "mp3/beat-B09.mp3",
      "actual_duration_s": 10.88,

        "at": "2026-07-18T16:35:44"
      }
    },
    {
      "beat_id": "B08",
      "estimated_duration_s": 10,
      "narration_text": "This is not a one-dimensional string bent into a circle. Exact disk modes follow two-dimensional radial geometry, so diameter divided by an integer is not the right wavelength rule.",
      "shot": {
        "type": "GRAPHIC",
        "source": "own",
        "motion": "reject"
      },
      "audio_file": "mp3/beat-B08.mp3",

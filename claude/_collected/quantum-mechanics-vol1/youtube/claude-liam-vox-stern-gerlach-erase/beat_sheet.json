        "remotion": {
          "pattern": "ClaudeComposerAsk",
          "provenance": "proven-core/ClaudeComposerAsk",
          "version": "1",
          "props": {
            "command": "Why does a Z-up spin become 50/50 in Z after an intervening X measurement?",
            "topic": "QUANTUM MECHANICS — INCOMPATIBLE MEASUREMENTS",
            "segment": "Certainty Lost Sideways",
            "greeting": "Hallo, Liam",
            "runningText": "tracking Z → X → Z…",
            "output": [
              "Z-up is a superposition in the X basis.",
              "The X measurement changes the state."
            ],
            "folderLabel": "@NikBearBrown",

    {
      "beat_id": "B03",
      "act": "CODE",
      "role_note": "terminal (Onda) -- reading the generated code",
      "narration_text": "The permission matrix printer formats each access type as a row: type, read or write, reversible, blast radius, and required flag. Browser row gets a red flag immediately.",
      "shot": {
        "type": "GRAPHIC",
        "source": "remotion",
        "motion": "fade",
        "remotion": {
          "pattern": "NikBearBrownCodeBlock",
          "props": {
            "filename": "permission_matrix.py",
            "topic": "AGENTIC AI",
            "segment": "ACTION SURFACE",
            "code": "MATRIX = [\n (\"chat\",      \"read\",  \"Y\", \"low\",  \"Y\"),\n (\"file-read\",  \"read\",  \"Y\", \"low\",  \"Y\"),\n (\"file-write\", \"write\", \"N\", \"med\",  \"Y\"),\n (\"browser\",    \"read\",  \"N\", \"high\", \"N\"),\n (\"terminal\",   \"exec\",  \"N\", \"high\", \"N\"),\n]\nhdr = \"TYPE        RW     REV  BLAST  REQ\"\nprint(hdr); print(\"-\"*len(hdr))\nfor t, rw, rev, blast, req in MATRIX:\n    flag = \"  <- NOT REQUIRED\" if req==\"N\" else \"\"\n    print(f\"{t:<12}{rw:<7}{rev:<5}{blast:<7}{req}{flag}\")"
          },
          "rendered": {
            "out": "media/B03.mp4",
            "at": ""
          }
        }
